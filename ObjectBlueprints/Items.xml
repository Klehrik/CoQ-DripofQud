        <tag Name="Tier" Value="1" />
		<stag Name="Contemporary" />
    </object>
    <object Name="DoQ_Poncho" Inherits="BaseCloak">
        <part Name="Armor" AV="0" DV="0" WornOn="Back" />
        <part Name="Render" DisplayName="poncho" Tile="Klehrik_DripofQud/Poncho.png" ColorString="&amp;K" DetailColor="y" RenderString="]" />
        <part Name="Commerce" Value="25" />
        <part Name="Description" Short="Synthetic fibers are bound watertight and knit into a lightweight protective covering." />
        <part Name="Physics" Weight="3" Organic="true" Category="Clothes" />
        <part Name="DoQ_LiquidProof" />
        <tag Name="Tier" Value="2" />
    </object>

    <!-- Arm -->
    <object Name="DoQ_Cuff" Inherits="BaseArmlet">
        <part Name="Armor" AV="2" DV="-2" WornOn="Arm" />
        <part Name="Render" DisplayName="{{Y|steel}} cuff" Tile="Klehrik_DripofQud/Cuff.png" ColorString="&amp;y" DetailColor="Y" RenderString="]" />
        <part Name="Commerce" Value="40" />
