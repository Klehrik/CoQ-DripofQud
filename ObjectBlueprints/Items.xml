        <part Name="Physics" Weight="3" />
        <tag Name="Tier" Value="3" />
        <tag Name="Mods" Value="CommonMods,BracerMods" />
    </object>

    <!-- Hands -->
    <object Name="DoQ_RubberGloves" Inherits="BaseGlove">
        <part Name="Armor" AV="0" DV="0" Elec="8" WornOn="Hands" />
        <part Name="Render" DisplayName="{{W|rubber}} gloves" ColorString="&amp;W" DetailColor="c" Tile="Items/sw_gloves_skintight.bmp" RenderString="]" />
        <part Name="Commerce" Value="8" />
        <part Name="Description" Short="Low-cost rubber implements tailored for electrical work and tinkering." />
        <part Name="Physics" Weight="1" Conductivity="0" />
        <part Name="Springy" Factor="0.9" />
        <tag Name="EquipSound" Value="sfx_equip_armor_synthetic" />
        <tag Name="Tier" Value="2" />
    </object>

    <!-- Feet -->
    <object Name="DoQ_PowerBoots" Inherits="BaseBoot">
        <part Name="Armor" AV="1" DV="1" WornOn="Feet" />
        <part Name="Render" DisplayName="{{mercurial|kinetic}} boots" Tile="Klehrik_DripofQud/PowerBoots.png" ColorString="&amp;C" DetailColor="W" RenderString="]" />
        <part Name="Examiner" Complexity="5" />
        <part Name="Commerce" Value="240" />
        <part Name="Description" Short="Miniaturized flywheels store ambient kinetic energy in anticipation for a release into ground-facing pistons." />
        <part Name="Physics" Weight="10" />
        <part Name="Metal" />
        <part Name="MoveCostMultiplier" Amount="-5" />
        <part Name="DoQ_ChargeAndJumpBoost" Jump="2" Charge="3" />
        <tag Name="EquipSound" Value="sfx_equip_armor_metal_light" />
        <tag Name="Tier" Value="5" />
        <stag Name="Movement" />
    </object>
    <object Name="DoQ_HikingBoots" Inherits="BaseBoot">
        <part Name="Armor" AV="0" DV="0" WornOn="Feet" />
        <part Name="Render" DisplayName="hiking boots" Tile="Klehrik_DripofQud/HikingBoots.png" ColorString="&amp;w" DetailColor="K" RenderString="]" />
        <part Name="Commerce" Value="14" />
        <part Name="Description" Short="Stiff hide lines the walls to support a leather base, and tough rubber undercoats the outsole for superior traction." />
        <part Name="Physics" Weight="3" />
        <part Name="SaveModifier" Vs="Move,Knockdown,Restraint" Amount="2" />
        <tag Name="Tier" Value="2" />
    </object>

