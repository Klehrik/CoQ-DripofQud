<objects>
    <!-- Item -->
    <object Name="DoQ_ItemDye" Inherits="Item">
        <part Name="Render" DisplayName="spray {{R-G-B sequence|dye}}" Tile="Klehrik_DripofQud/Spray.png" ColorString="&amp;y" DetailColor="B" RenderString="012" />
        <part Name="Examiner" Complexity="1" Alternate="UnknownBottle" />
        <part Name="Commerce" Value="16" />
        <part Name="Description" Short="An aerosol can blown full of various pigments." />
        <part Name="Applicator" />
        <part Name="DoQ_ItemDye" />
        <tag Name="EquipSound" Value="sfx_equip_material_sprayBottle" />
        <tag Name="Gift" Value="*noinherit" />
        <tag Name="Tier" Value="1" />
        <stag Name="Tool" />
    </object>

    <!-- Head -->
    <object Name="DoQ_PointedHat" Inherits="BaseHat">
        <part Name="Armor" AV="1" DV="0" Intelligence="1" Ego="1" WornOn="Head" />
        <part Name="Render" DisplayName="pointed hat" Tile="Klehrik_DripofQud/PointedHat.png" ColorString="&amp;r" DetailColor="W" RenderString="]" />
        <part Name="Commerce" Value="95" />
        <part Name="Description" Short="Deep-dyed goatskin is flattened into a disk shape and pushed triangularly skyward to a tapered point." />
        <part Name="Physics" Weight="1" Organic="true" />
        <tag Name="Tier" Value="4" />
        <tag Name="DynamicObjectsTable:Headwear" />
		<stag Name="Scholarly" />
        <part Name="ItemElements" Elements="scholarship::4" />
    </object>
    <object Name="DoQ_TopHat" Inherits="BaseHat">
        <part Name="Armor" AV="1" DV="0" Ego="1" WornOn="Head" />
        <part Name="Render" DisplayName="top hat" Tile="Klehrik_DripofQud/TopHat.png" ColorString="&amp;K" DetailColor="y" RenderString="]" />
        <part Name="Commerce" Value="20" />
        <part Name="Description" Short="Silken fabric is wound around cylindrically to form a tall pillar with a flattened top." />
        <part Name="Physics" Weight="1" Organic="true" />
        <tag Name="Tier" Value="2" />
        <tag Name="DynamicObjectsTable:Headwear" />
    </object>

    <!-- Face -->
    <object Name="DoQ_Bandana" Inherits="BaseMask">
        <part Name="Armor" AV="0" DV="1" Agility="1" WornOn="Face" />
        <part Name="Render" DisplayName="bandana" Tile="Klehrik_DripofQud/Bandana.png" ColorString="&amp;r" RenderString="]" />
        <part Name="Commerce" Value="20" />
        <part Name="Description" Short="Cut cloth is wrapped into a guard about the face and fastened tight at the back." />
        <part Name="Physics" Weight="1" Organic="true" />
        <tag Name="Tier" Value="2" />
    </object>
    <object Name="DoQ_Rangefinder" Inherits="BaseMask">
        <part Name="Armor" AV="0" DV="0" WornOn="Face" />
        <part Name="Render" DisplayName="{{c|range}}{{O|finder}}" Tile="Klehrik_DripofQud/Rangefinder.png" ColorString="&amp;c" DetailColor="O" RenderString="]" />
        <part Name="Examiner" Complexity="4" />
        <part Name="Commerce" Value="50" />
        <part Name="Description" Short="The head-mounted apparatus's screen fits snug over the eye, relaying targeting information to its user." />
        <part Name="Physics" Weight="4" />
        <part Name="PowerSwitch" EnergyCost="100" FlippableWithoutUnderstanding="true" ActivateSuccessMessage="" ActivateFailureMessage="" DeactivateSuccessMessage="" DeactivateFailureMessage="" />
        <part Name="EnergyCellSocket" SlotType="EnergyCell" />
        <part Name="AIDefensiveEnergyCellReload" />
        <part Name="AIPassiveEnergyCellReload" />
        <part Name="Metal" />
        <part Name="TinkerItem" Bits="0124" CanDisassemble="true" CanBuild="true" />
        <part Name="DoQ_Rangefinder" ChargeUse="2" Value="2" />
        <tag Name="EquipSound" Value="sfx_equip_armor_artifact_light" />
        <tag Name="Tier" Value="4" />
    </object>
    <object Name="DoQ_Balaclava" Inherits="BaseMask">
        <part Name="Armor" AV="0" DV="1" Cold="10" WornOn="Face" />
        <part Name="Render" DisplayName="balaclava" Tile="Klehrik_DripofQud/Balaclava.png" ColorString="&amp;K" RenderString="]" />
        <part Name="Commerce" Value="12" />
        <part Name="Description" Short="Woolen fibers are crocheted into a warm shell for the face." />
        <part Name="Physics" Weight="1" Organic="true" />
        <tag Name="Tier" Value="2" />
    </object>

    <!-- Body -->
    <object Name="DoQ_Jacket" Inherits="BaseArmor">
        <part Name="Armor" AV="0" DV="1" Cold="10" CarryBonus="5" WornOn="Body" />
        <part Name="Render" DisplayName="puffer jacket" Tile="Klehrik_DripofQud/Jacket.png" ColorString="&amp;W" DetailColor="w" RenderString="]" />
        <part Name="Commerce" Value="25" />
        <part Name="Description" Short="Yellow-stained synthetic material is partitioned into sections encasing soft down, forming a lightweight garb. Small pockets are strewn onto the sides, acting as nests for the hands." />
        <part Name="Physics" Weight="2" />
	    <tag Name="EquipSound" Value="sfx_equip_armor_synthetic" />
        <tag Name="Tier" Value="2" />
    </object>

